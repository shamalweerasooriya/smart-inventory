{
  "realm": "inventory-saas",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Administrator with full access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "USER",
        "description": "Read-only user",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "inventory-app",
      "name": "Inventory Frontend App",
      "description": "Confidential client for the Next.js frontend (server-side auth)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "inventory-app-secret",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "+"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "tenantId-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenantId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenantId",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "inventory-backend-admin",
      "name": "Inventory Backend Admin",
      "description": "Confidential client for backend to call Keycloak Admin REST API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "backend-admin-secret",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": false
    }
  ],
  "users": [
    {
      "username": "admin@demo.com",
      "email": "admin@demo.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "Admin",
      "attributes": {
        "tenantId": ["demo-tenant-001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    },
    {
      "username": "user@demo.com",
      "email": "user@demo.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "User",
      "attributes": {
        "tenantId": ["demo-tenant-001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ]
    }
  ]
}
